# Azure AD SSO for the student/admin sign-in (optional).
# Leave blank to use dev-login (students) and the env-gated local-login (admins).
VITE_AZURE_AD_CLIENT_ID=
VITE_AZURE_AD_TENANT_ID=
VITE_AZURE_AD_REDIRECT_URI=http://localhost:3000

# VITE_ALLOW_DEV_LOGIN=false — only affects built bundles; npm run dev always shows the dev login

# VITE_API_PROXY_TARGET must be set in the SHELL (VITE_API_PROXY_TARGET=... npm run dev) —
# vite.config.ts reads process.env before this file is loaded, so setting it here has no effect.
